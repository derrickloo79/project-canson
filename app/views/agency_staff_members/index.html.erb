<% content_for :title, "Staff Roster — FlexiLabour" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold">Staff Roster</h1>
    <p class="text-sm text-base-content/60 mt-0.5"><%= @agency.name %></p>
  </div>
  <% if current_user.role_agency_admin? %>
    <%= link_to "Add Staff Member", new_agency_staff_member_path, class: "btn btn-primary btn-sm" %>
  <% end %>
</div>

<% if @staff_members.empty? %>
  <div class="text-center py-16 text-base-content/50">
    <p class="text-lg">No staff members yet.</p>
    <p class="mt-1">Add staff to your roster so you can submit them for hotel staffing requests.</p>
    <% if current_user.role_agency_admin? %>
      <%= link_to "Add your first staff member", new_agency_staff_member_path, class: "btn btn-primary btn-sm mt-4" %>
    <% end %>
  </div>
<% else %>
  <div class="card bg-base-100 border border-base-200 shadow-sm overflow-x-auto">
    <table class="table table-zebra" data-controller="table-sort">
      <thead>
        <tr>
          <th data-action="click->table-sort#sort" data-table-sort-target="header" class="cursor-pointer select-none">Name</th>
          <th data-action="click->table-sort#sort" data-table-sort-target="header" class="cursor-pointer select-none">Email</th>
          <th data-action="click->table-sort#sort" data-table-sort-target="header" class="cursor-pointer select-none">Mobile</th>
          <th data-action="click->table-sort#sort" data-table-sort-target="header" class="cursor-pointer select-none">Gender</th>
          <th data-action="click->table-sort#sort" data-table-sort-target="header" class="cursor-pointer select-none">Roles</th>
          <th data-action="click->table-sort#sort" data-table-sort-target="header" class="cursor-pointer select-none">Status</th>
          <% if current_user.role_agency_admin? %>
            <th></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% @staff_members.each do |member| %>
          <tr class="<%= 'opacity-60' unless member.active? %>">
            <td class="font-medium"><%= member.name %></td>
            <td class="text-sm text-base-content/70"><%= member.email %></td>
            <td class="text-sm text-base-content/70"><%= member.mobile.presence || "—" %></td>
            <td><%= render "gender_badge", gender: member.gender %></td>
            <td>
              <div class="flex flex-wrap gap-1">
                <% if member.roles.any? %>
                  <% member.roles.each do |role| %>
                    <span class="badge badge-neutral badge-sm"><%= role.name %></span>
                  <% end %>
                <% else %>
                  <span class="text-base-content/40 text-sm">—</span>
                <% end %>
              </div>
            </td>
            <td>
              <% if member.active? %>
                <span class="badge badge-success badge-sm">Active</span>
              <% else %>
                <span class="badge badge-ghost badge-sm">Inactive</span>
              <% end %>
            </td>
            <% if current_user.role_agency_admin? %>
              <td>
                <div class="flex gap-1">
                  <%= link_to edit_agency_staff_member_path(member), class: "btn btn-ghost btn-xs btn-square", title: "Edit" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                  <% end %>
                  <%= button_to agency_staff_member_path(member), method: :delete,
                      class: "btn btn-ghost btn-xs btn-square text-error",
                      title: "Remove",
                      data: { turbo_confirm: "Remove #{member.name} from your roster?" } do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                  <% end %>
                </div>
              </td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
