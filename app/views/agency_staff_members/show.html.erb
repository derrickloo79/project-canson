<% content_for :title, "#{@staff_member.name} — FlexiLabour" %>

<div class="max-w-4xl mx-auto">

  <div class="flex items-center gap-3 mb-6">
    <%= link_to agency_staff_members_path, class: "btn btn-ghost btn-sm btn-square" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    <% end %>
    <div class="flex-1 flex items-center gap-3">
      <h1 class="text-2xl font-bold"><%= @staff_member.name %></h1>
      <% if @staff_member.blacklisted? %>
        <span class="badge badge-error">Blacklisted</span>
      <% elsif @staff_member.active? %>
        <span class="badge badge-success">Active</span>
      <% else %>
        <span class="badge badge-ghost">Inactive</span>
      <% end %>
    </div>
    <% if current_user.role_agency_admin? %>
      <div class="flex items-center gap-2">
        <%= link_to "Edit", edit_agency_staff_member_path(@staff_member), class: "btn btn-outline btn-sm" %>
        <% unless @staff_member.blacklisted? %>
          <button type="button" class="btn btn-outline btn-warning btn-sm"
                  onclick="document.getElementById('blacklist-modal').showModal()">
            Blacklist
          </button>
        <% end %>
        <%= button_to "Remove", agency_staff_member_path(@staff_member), method: :delete,
            class: "btn btn-outline btn-error btn-sm",
            data: { turbo_confirm: "Remove \"#{@staff_member.name}\" from your roster? This cannot be undone." } %>
      </div>
    <% end %>
  </div>

  <%# Blacklist notice %>
  <% if @staff_member.blacklisted? %>
    <div role="alert" class="alert alert-error mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
      </svg>
      <div class="flex-1">
        <p class="font-semibold">This staff member is blacklisted.</p>
        <% if @staff_member.blacklist_reason.present? %>
          <p class="text-sm mt-0.5"><%= @staff_member.blacklist_reason %></p>
        <% end %>
        <p class="text-xs mt-1 opacity-70">
          Blacklisted <%= @staff_member.blacklisted_at&.strftime("%-d %b %Y") %>
          <% if @staff_member.blacklisted_by.present? %>
            by <%= @staff_member.blacklisted_by.name %>
          <% end %>
        </p>
      </div>
      <% if current_user.role_agency_admin? %>
        <%= button_to "Reinstate", unblacklist_agency_staff_member_path(@staff_member), method: :patch,
            class: "btn btn-sm btn-outline",
            data: { turbo_confirm: "Reinstate \"#{@staff_member.name}\"?" } %>
      <% end %>
    </div>
  <% end %>

  <div class="card bg-base-200 border border-base-200 shadow-sm">
    <div class="card-body">
      <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
        <div>
          <dt class="text-base-content/50 text-xs uppercase tracking-wide">Email</dt>
          <dd class="mt-1 font-medium"><%= mail_to @staff_member.email, @staff_member.email %></dd>
        </div>
        <div>
          <dt class="text-base-content/50 text-xs uppercase tracking-wide">Mobile</dt>
          <dd class="mt-1 font-medium"><%= @staff_member.mobile.presence || "—" %></dd>
        </div>
        <div>
          <dt class="text-base-content/50 text-xs uppercase tracking-wide">Gender</dt>
          <dd class="mt-1 font-medium"><%= @staff_member.gender&.humanize&.gsub("_", " ") || "—" %></dd>
        </div>
        <div>
          <dt class="text-base-content/50 text-xs uppercase tracking-wide">Added</dt>
          <dd class="mt-1 font-medium"><%= @staff_member.created_at.strftime("%-d %b %Y") %></dd>
        </div>
        <div class="sm:col-span-2">
          <dt class="text-base-content/50 text-xs uppercase tracking-wide mb-2">Roles</dt>
          <dd>
            <% if @staff_member.roles.any? %>
              <div class="flex flex-wrap gap-2">
                <% @staff_member.roles.ordered.each do |role| %>
                  <span class="badge badge-neutral"><%= role.name %></span>
                <% end %>
              </div>
            <% else %>
              <span class="text-base-content/40">No roles assigned</span>
            <% end %>
          </dd>
        </div>
      </dl>
    </div>
  </div>

  <%# Blacklist modal %>
  <% if current_user.role_agency_admin? && !@staff_member.blacklisted? %>
    <dialog id="blacklist-modal" class="modal">
      <div class="modal-box">
        <h3 class="font-bold text-lg">Blacklist staff member?</h3>
        <p class="text-sm text-base-content/60 mt-1 mb-4">
          "<%= @staff_member.name %>" will be flagged and excluded from future staffing submissions.
        </p>
        <%= form_with url: blacklist_agency_staff_member_path(@staff_member), method: :patch do |f| %>
          <div class="form-control mb-4">
            <label class="label">
              <span class="label-text font-medium">Reason <span class="text-error">*</span></span>
            </label>
            <%= f.text_area :blacklist_reason, rows: 3,
                class: "textarea textarea-bordered w-full",
                placeholder: "Provide a reason for blacklisting this staff member…",
                required: true %>
          </div>
          <div class="modal-action">
            <button type="button" class="btn btn-ghost"
                    onclick="document.getElementById('blacklist-modal').close()">
              Cancel
            </button>
            <%= f.submit "Blacklist", class: "btn btn-error" %>
          </div>
        <% end %>
      </div>
      <form method="dialog" class="modal-backdrop">
        <button>close</button>
      </form>
    </dialog>
  <% end %>

</div>
