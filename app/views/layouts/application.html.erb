<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "FlexiLabour" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="FlexiLabour">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-base-100">
    <nav class="flex items-center justify-between bg-white border-b border-base-200 px-6 h-14 sticky top-0 z-50">
      <div class="flex items-center gap-6 left-section">
        <%= link_to "FlexiLabour", root_path, class: "text-base font-bold tracking-tight" %>
        <% if user_signed_in? %>
          <% if current_user.role_flexible_staff? %>
            <%# Flexible staff: only see their own invitations %>
            <div class="flex items-center gap-1.5">
              <%= link_to "Invitations", invitations_path, class: "text-sm text-base-content/70 hover:text-base-content transition-colors" %>
              <% pending_count = current_user.staff_member&.event_invitations&.status_pending&.count || 0 %>
              <% if pending_count > 0 %>
                <span class="badge badge-warning badge-xs"><%= pending_count %></span>
              <% end %>
            </div>
          <% elsif current_user.agency_user? %>
            <%# Agency admins and managers %>
            <%= link_to "Dashboard", agency_dashboard_path, class: "text-sm text-base-content/70 hover:text-base-content transition-colors" %>
          <% else %>
            <%# Ops managers, approving managers, admins %>
            <%= link_to "Events", events_path, class: "text-sm text-base-content/70 hover:text-base-content transition-colors" %>
            <%= link_to "Staff", staff_members_path, class: "text-sm text-base-content/70 hover:text-base-content transition-colors" %>
            <% if current_user.role_approving_manager? || current_user.role_system_admin? %>
              <div class="flex items-center gap-1.5">
                <%= link_to "Approvals", approvals_path, class: "text-sm text-base-content/70 hover:text-base-content transition-colors" %>
                <% pending_count = current_user.managed_users.sum { |u| u.events.status_pending_approval.count } %>
                <% if pending_count > 0 %>
                  <span class="badge badge-warning badge-xs"><%= pending_count %></span>
                <% end %>
              </div>
              <%= link_to "Roles", roles_path, class: "text-sm text-base-content/70 hover:text-base-content transition-colors" %>
            <% end %>
            <% if current_user.role_system_admin? %>
              <%= link_to "Agencies", agencies_path, class: "text-sm text-base-content/70 hover:text-base-content transition-colors" %>
            <% end %>
          <% end %>
        <% end %>
      </div>
      <div class="flex items-center gap-4 right-section">
        <% if user_signed_in? %>
          <div class="dropdown dropdown-end">
            <div tabindex="0" role="button" class="flex items-center gap-2 text-sm text-base-content/70 hover:text-base-content transition-colors cursor-pointer">
              <% initials = current_user.name.presence&.then { |n| parts = n.split; "#{parts.first[0]}#{parts.last[0]}" if parts.size >= 1 } %>
              <div class="w-7 h-7 rounded-full bg-neutral text-neutral-content flex items-center justify-center text-xs font-semibold uppercase">
                <%= initials || current_user.email[0] %>
              </div>
              <%= current_user.name.presence || current_user.email %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
            <ul tabindex="0" class="dropdown-content menu bg-white border border-base-200 rounded-box z-10 w-36 p-1 shadow-sm mt-1">
              <li>
                <%= button_to "Sign out", destroy_user_session_path,
                    method: :delete,
                    class: "text-sm text-base-content/70 hover:text-base-content w-full text-left px-3 py-1.5" %>
              </li>
            </ul>
          </div>
        <% else %>
          <%= link_to "Sign in", new_user_session_path, class: "text-sm text-base-content/70 hover:text-base-content transition-colors" %>
        <% end %>
      </div>
    </nav>

    <% if notice.present? %>
      <div class="alert alert-success mx-4 mt-4" role="alert">
        <%= notice %>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="alert alert-error mx-4 mt-4" role="alert">
        <%= alert %>
      </div>
    <% end %>

    <main class="container mx-auto px-4 py-8">
      <%= yield %>
    </main>
  </body>
</html>
