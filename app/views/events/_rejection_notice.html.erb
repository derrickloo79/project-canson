<% if event.status_rejected? && event.rejection_reason.present? %>
  <div role="alert" class="alert alert-error mb-6">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 shrink-0 stroke-current" fill="none" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
    <div>
      <p class="font-semibold">This event was rejected.</p>
      <p class="text-sm mt-0.5"><%= event.rejection_reason %></p>
    </div>
    <%= link_to "Edit & Resubmit", step1_event_path(event), class: "btn btn-sm btn-outline btn-error ml-auto shrink-0" %>
  </div>
<% end %>
