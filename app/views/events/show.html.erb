<% content_for :title, "#{@event.event_name} — FlexiLabour" %>

<%
  invitation_phase = @event.status_approved? || @event.status_invitation_open? || @event.status_fully_staffed?
%>

<div class="max-w-4xl mx-auto">

  <div class="flex mb-6">
    <% if current_user.role_approving_manager? %>
      <%= link_to approvals_path, class: "btn btn-ghost btn-sm btn-square" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      <% end %>
    <% else %>
        <%= link_to events_path, class: "btn btn-ghost btn-sm btn-square" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      <% end %>
    <% end %>
  </div>

  <%= render "rejection_notice", event: @event %>

  <%# Header %>
  <div class="flex items-start justify-between mb-6">
    <div class="flex flex-col gap-2">
      <div class="flex items-center gap-3">
        <h1 class="text-2xl font-bold"><%= @event.event_name %></h1>
        <%= render "event_status_badge", event: @event %>
      </div>
      <div class="flex items-center flex-wrap gap-x-3 gap-y-1 mt-1 text-base-content/60 text-sm">
        <span class="flex items-center gap-1.5 whitespace-nowrap">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <%= @event.event_date&.strftime("%a, %-d %b %Y") %>
          <% if @event.multi_day? && @event.event_end_date %>
            <span>–</span>
            <%= @event.event_end_date.strftime("%a, %-d %b %Y") %>
            <span class="badge badge-outline badge-xs uppercase">Multi-day</span>
          <% end %>
        </span>
        <span class="flex items-center gap-1.5 whitespace-nowrap">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <%= @event.venue %>
        </span>
        <% if invitation_phase %>
          <%
            confirmed = @event.confirmed_staff_count
            total     = @event.total_vacancies
            fill_class = confirmed >= total ? "badge-success" : (confirmed > 0 ? "badge-warning" : "badge-neutral")
          %>
          <span class="badge <%= fill_class %> badge-sm gap-1">
            <%= confirmed %> / <%= total %> confirmed
          </span>
        <% end %>
      </div>
    </div>
  </div>

  <% if @event.status_pending_approval? %>
    <div class="alert alert-info">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
           class="h-6 w-6 shrink-0 stroke-current">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
      </svg>
      <span>
        This event has been submitted and is awaiting approval.
        Full event management tabs will be available once approved.
      </span>
    </div>
  <% end %>

  <% if invitation_phase %>
    <%# ── Tabbed layout for invitation phase ────────────────────────────── %>
    <div role="tablist" class="tabs tabs-border mt-4">

      <%# Tab 1 — Overview %>
      <input type="radio" name="event_tabs" role="tab" class="tab" aria-label="Overview" checked />
      <div role="tabpanel" class="tab-content pt-6">
        <div class="card bg-base-200 shadow-sm">
          <div class="card-body">
            <%# <h2 class="card-title">Event Details</h2> %>
            <dl class="grid grid-cols-4 gap-x-4 gap-y-2 text-sm mt-2">
              <%= render "event_basics_rows", event: @event %>
            </dl>
          </div>
        </div>
      </div>

      <%# Tab 2 — Roles & Vacancies %>
      <input type="radio" name="event_tabs" role="tab" class="tab" aria-label="Roles &amp; Vacancies" />
      <div role="tabpanel" class="tab-content pt-6">
        <div class="space-y-4">
          <% @event.event_roles.each do |role| %>
            <%
              cnt           = role.confirmed_count
              inhouse_cnt   = role.inhouse_confirmed_count
              agency_cnt    = role.agency_confirmed_count
              vac           = role.vacancies
              fill_badge    = cnt >= vac ? "badge-success" : (cnt > 0 ? "badge-warning" : "badge-neutral")
              confirmed_invitations   = role.event_invitations.select(&:status_accepted?)
              accepted_agency_candidates = role.agency_staffing_requests.flat_map { |req|
                req.agency_staffing_candidates.select(&:status_accepted?)
              }
            %>
            <div class="card bg-base-200 border border-base-200 shadow-sm">
              <div class="card-body gap-3">
                <div class="flex">  
                  <div class="flex flex-col gap-2 flex-1">
                    <%# Row 1: role name + shift + rate + fill badge %>
                    <div class="flex items-center gap-3 flex-wrap">
                    <h3 class="font-bold text-base"><%= role.role_name %></h3>
                    <span class="flex items-center gap-1.5 text-sm text-base-content/60">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <%= role.shift_start&.strftime("%H:%M") %> – <%= role.shift_end&.strftime("%H:%M") %>
                      <% if role.shift_end_next_day? %>
                        <span class="badge badge-warning badge-xs">+1</span>
                      <% end %>
                    </span>
                    <span class="flex items-center gap-1.5 text-sm text-base-content/60">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      <%= role.rate ? "$#{number_with_precision(role.rate, precision: 2)}/hr" : "—" %>
                    </span>
                    <span class="badge <%= fill_badge %> badge-sm whitespace-nowrap">
                      <%= cnt %> / <%= vac %> Filled
                    </span>
                    </div>

                    <%# Row 2: requirements %>
                    <% if role.requirements.present? %>
                      <p class="text-sm text-base-content/60"><%= role.requirements %></p>
                    <% end %>

                    <%# Row 3: source breakdown + Invite button, right-aligned %>
                    <div class="flex text-sm gap-6">
                      <div class="flex gap-2 items-center">
                        <p class="text-base-content/50 text-xs uppercase tracking-wide">In-House</p>
                        <p class="font-semibold"><%= inhouse_cnt %></p>
                      </div>
                      <div class="flex gap-2 items-center">
                        <p class="text-base-content/50 text-xs uppercase tracking-wide">Agency</p>
                        <p class="font-semibold"><%= agency_cnt %></p>
                      </div>
                      <div class="flex gap-2 items-center">
                        <p class="text-base-content/50 text-xs uppercase tracking-wide">External Referral</p>
                        <p class="font-semibold">0</p>
                      </div>
                    </div>
                  </div>
                  <% if current_user.role_ops_manager? %>
                    <label for="tab-staff" class="btn btn-outline btn-sm cursor-pointer">Invite</label>
                  <% end %>
                </div>
                <%# Confirmed staff table %>
                <% if confirmed_invitations.any? || accepted_agency_candidates.any? %>
                  <div class="overflow-x-auto mt-1">
                    <table class="table w-full" data-controller="table-sort">
                      <thead>
                        <tr>
                          <th data-action="click->table-sort#sort" data-table-sort-target="header" class="cursor-pointer select-none">Full Name</th>
                          <th data-action="click->table-sort#sort" data-table-sort-target="header" class="cursor-pointer select-none">Email</th>
                          <th data-action="click->table-sort#sort" data-table-sort-target="header" class="cursor-pointer select-none">Mobile</th>
                          <th data-action="click->table-sort#sort" data-table-sort-target="header" class="cursor-pointer select-none">Gender</th>
                          <th data-action="click->table-sort#sort" data-table-sort-target="header" class="cursor-pointer select-none">Source</th>
                          <th data-action="click->table-sort#sort" data-table-sort-target="header" class="cursor-pointer select-none">Accepted</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% confirmed_invitations.each do |inv| %>
                          <tr>
                            <td class="font-medium"><%= inv.staff_member.name %></td>
                            <td class="text-base-content/60"><%= inv.staff_member.email %></td>
                            <td class="text-base-content/60"><%= inv.staff_member.mobile.presence || "—" %></td>
                            <td><%= render "gender_badge", gender: inv.staff_member.gender %></td>
                            <td><span class="badge badge-neutral badge-ghost badge-sm">In-House</span></td>
                            <td class="text-base-content/60 whitespace-nowrap" data-sort-value="<%= inv.responded_at&.iso8601 || "" %>">
                              <%= inv.responded_at&.strftime("%-d %b %Y %H:%M") || "—" %>
                            </td>
                          </tr>
                        <% end %>
                        <% accepted_agency_candidates.each do |candidate| %>
                          <% m = candidate.agency_staff_member %>
                          <tr>
                            <td class="font-medium"><%= m.name %></td>
                            <td class="text-base-content/60"><%= m.email %></td>
                            <td class="text-base-content/60"><%= m.mobile.presence || "—" %></td>
                            <td><%= render "gender_badge", gender: m.gender %></td>
                            <td><span class="badge badge-neutral badge-ghost badge-sm">Agency</span></td>
                            <td class="text-base-content/60 whitespace-nowrap" data-sort-value="<%= candidate.accepted_at&.iso8601 || "" %>">
                              <%= candidate.accepted_at&.strftime("%-d %b %Y %H:%M") || "—" %>
                            </td>
                          </tr>
                        <% end %>
                      </tbody>
                    </table>
                  </div>
                <% else %>
                  <p class="text-center text-base-content/40 text-sm py-2">No Data</p>
                <% end %>

              </div>
            </div>
          <% end %>
        </div>
      </div>

      <%# Tab 3 — Staff (In-House) — ops managers only %>
      <% if current_user.role_ops_manager? %>
        <input type="radio" id="tab-staff" name="event_tabs" role="tab" class="tab" aria-label="In-House Staff" />
        <div role="tabpanel" class="tab-content pt-6">
          <div class="card bg-base-200 shadow-sm">
            <div class="card-body">
              <h2 class="card-title">In-House Staff</h2>
              <% @event.event_roles.each do |role| %>
                <%= render "events/staff_role_panel", role: role %>
              <% end %>
            </div>
          </div>
        </div>

        <%# Tab 4 — Agencies %>
        <input type="radio" id="tab-agencies" name="event_tabs" role="tab" class="tab" aria-label="Agencies" />
        <div role="tabpanel" class="tab-content pt-6">
          <%= render "events/agencies_tab", event: @event, connected_agencies: @connected_agencies %>
        </div>
      <% end %>

    </div>

  <% else %>
    <%# ── Flat layout for draft / pending_approval / rejected ─────────── %>
    <div class="card bg-base-200 shadow-sm mt-6">
      <div class="card-body">
        <h2 class="card-title">Event Details</h2>
        <dl class="grid grid-cols-4 gap-x-4 gap-y-2 text-sm mt-2">
          <%= render "event_basics_rows", event: @event %>
        </dl>
      </div>
    </div>

    <div class="card bg-base-200 shadow-sm mt-4">
      <div class="card-body">
        <h2 class="card-title">
          Roles
          <span class="text-base font-normal text-base-content/60">
            (<%= @event.event_roles.size %> roles,
             <%= @event.total_vacancies %> vacancies,
             est. $<%= number_with_precision(@event.estimated_total_cost, precision: 2, delimiter: ",") %>)
          </span>
        </h2>
        <div class="overflow-x-auto mt-2">
          <table class="table w-full">
            <thead>
              <tr>
                <th>Role</th>
                <th>Vacancies</th>
                <th>Shift</th>
                <th>Rate ($/hr)</th>
                <th>Requirements</th>
              </tr>
            </thead>
            <tbody>
              <% @event.event_roles.each do |role| %>
                <tr>
                  <td class="font-medium"><%= role.role_name %></td>
                  <td><%= role.vacancies %></td>
                  <td class="flex items-center gap-1">
                    <%= role.shift_start&.strftime("%H:%M") %> –
                    <%= role.shift_end&.strftime("%H:%M") %>
                    <% if role.shift_end_next_day? %>
                      <span class="badge badge-warning badge-sm ml-1">+1</span>
                    <% end %>
                  </td>
                  <td><%= role.rate ? number_with_precision(role.rate, precision: 2, delimiter: ",") : "—" %></td>
                  <td class="text-sm text-base-content/70"><%= role.requirements.presence || "—" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  <% end %>

</div>