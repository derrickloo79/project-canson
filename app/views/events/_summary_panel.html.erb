<div class="card bg-base-200 shadow-sm h-fit sticky top-4"
     data-role-rows-target="summary">
  <div class="card-body p-4">
    <h3 class="font-semibold text-base mb-3">Summary</h3>

    <div class="stat p-0 py-2 border-b border-base-300">
      <div class="stat-title text-xs">Total Roles</div>
      <div class="stat-value text-2xl" data-summary-roles>0</div>
    </div>

    <div class="stat p-0 py-2 border-b border-base-300">
      <div class="stat-title text-xs">Total Vacancies</div>
      <div class="stat-value text-2xl" data-summary-vacancies>0</div>
    </div>

    <div class="stat p-0 py-2 border-b border-base-300">
      <div class="stat-title text-xs">Earliest Shift Start</div>
      <div class="stat-value text-lg" data-summary-start>—</div>
    </div>

    <div class="stat p-0 py-2">
      <div class="stat-title text-xs">Latest Shift End</div>
      <div class="stat-value text-lg" data-summary-end>—</div>
    </div>
  </div>
</div>
