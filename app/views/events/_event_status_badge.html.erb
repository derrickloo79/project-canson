<% badge_class = case event.status
  when "draft"            then "badge-neutral"
  when "pending_approval" then "badge-warning"
  when "rejected"         then "badge-error"
  when "approved"         then "badge-info"
  when "invitation_open"  then "badge-info"
  when "fully_staffed"    then "badge-success"
  when "ongoing"          then "badge-success"
  when "ended"            then "badge-neutral"
  when "cancelled"        then "badge-error"
  else                         "badge-neutral"
  end %>
<span class="badge <%= badge_class %> badge-sm whitespace-nowrap shrink-0"><%= event.status.humanize %></span>
