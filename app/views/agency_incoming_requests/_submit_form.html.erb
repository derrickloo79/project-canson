<%= form_with url: submit_candidates_agency_incoming_request_path(request), method: :patch, class: "space-y-4" do %>
  <% if roster.empty? %>
    <p class="text-sm text-base-content/50">
      No eligible staff members for this role in your roster.
      <%= link_to "Manage roster →", agency_staff_members_path, class: "link link-primary" %>
    </p>
  <% else %>
    <div data-controller="check-all">
      <div class="flex gap-3 mb-3 text-sm">
        <button type="button" data-action="check-all#selectAll"
                class="link link-primary">Select all</button>
        <button type="button" data-action="check-all#deselectAll"
                class="link link-neutral">Unselect all</button>
      </div>

      <div class="space-y-1">
        <% roster.each do |member| %>
          <label class="flex items-center gap-3 cursor-pointer hover:bg-base-200 rounded-lg p-2 transition-colors">
            <%= check_box_tag "agency_staff_member_ids[]", member.id,
                submitted_ids.include?(member.id),
                disabled: submitted_ids.include?(member.id),
                class: "checkbox checkbox-sm" %>
            <p class="font-medium text-sm flex-1 min-w-0"><%= member.name %></p>
            <%= render "gender_badge", gender: member.gender %>
            <% if submitted_ids.include?(member.id) %>
              <span class="badge badge-ghost badge-sm shrink-0">Already submitted</span>
            <% end %>
          </label>
        <% end %>
      </div>
    </div>
    <%= submit_tag "Submit Selected Candidates", class: "btn btn-primary btn-sm" %>
  <% end %>
<% end %>
