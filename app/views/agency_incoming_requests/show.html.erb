<% content_for :title, "Staffing Request — FlexiLabour" %>

<%
  event = @request.event_role.event
  role  = @request.event_role
%>

<div class="max-w-4xl mx-auto">
  <div class="flex items-center gap-3 mb-6">
    <%= link_to agency_incoming_requests_path, class: "btn btn-ghost btn-sm btn-square" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    <% end %>
    <h1 class="text-2xl font-bold">Staffing Request</h1>
  </div>

  <%# Request summary card %>
  <div class="card bg-base-200 border border-base-200 shadow-sm mb-6">
    <div class="card-body">
      <div class="flex items-start justify-between gap-3">
        <div>
          <h2 class="font-bold text-lg"><%= role.role_name %> <span class="font-normal">for</span> <%= event.event_name %></h2>
          <div class="flex items-center flex-wrap gap-x-3 gap-y-1 mt-1 text-base-content/60 text-sm">
            <span class="flex items-center gap-1.5 whitespace-nowrap">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <%= event.event_date&.strftime("%a, %-d %b %Y") %>
            </span>
            <span class="flex items-center gap-1.5 whitespace-nowrap">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
              <%= event.venue %>
            </span>
            <span class="flex items-center gap-1.5 whitespace-nowrap">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              <%= event.user.name %>
            </span>
          </div>
        </div>
        <% case @request.status
           when "pending" %>
          <span class="badge badge-warning">Pending</span>
        <% when "submitted" %>
          <span class="badge badge-info">Submitted</span>
        <% when "declined" %>
          <span class="badge badge-error">Declined</span>
        <% when "cancelled" %>
          <span class="badge badge-ghost">Cancelled</span>
        <% when "closed" %>
          <span class="badge badge-neutral">Closed</span>
        <% end %>
      </div>

      <dl class="grid grid-cols-4 gap-x-4 gap-y-2 text-sm mt-3">
        <dt class="text-base-content/60">Shift</dt>
        <dd class="col-span-3 flex items-center gap-1">
          <%= role.shift_start&.strftime("%H:%M") %> – <%= role.shift_end&.strftime("%H:%M") %>
          <% if role.shift_end_next_day? %>
            <span class="badge badge-warning badge-xs ml-1">+1</span>
          <% end %>
        </dd>

        <dt class="text-base-content/60">Staff Needed</dt>
        <dd class="col-span-3"><%= @request.vacancies_requested %></dd>

        <dt class="text-base-content/60">Received</dt>
        <dd class="col-span-3"><%= @request.created_at.strftime("%-d %b %Y") %></dd>

        <% if @request.notes.present? %>
          <dt class="text-base-content/60">Notes from Hotel</dt>
          <dd class="col-span-3"><%= @request.notes %></dd>
        <% end %>
      </dl>
    </div>
  </div>

  <% if @request.status_cancelled? %>
    <div class="alert alert-warning mb-6">
      <span>This request has been cancelled by the hotel.</span>
    </div>

  <% elsif @request.status_declined? %>
    <div class="alert alert-error mb-6">
      <div>
        <p class="font-semibold">You declined this request.</p>
        <% if @request.declined_reason.present? %>
          <p class="text-sm mt-1">Reason: <%= @request.declined_reason %></p>
        <% end %>
      </div>
    </div>

  <% elsif @request.status_submitted? %>
    <%# Show submitted candidates with hotel's decisions %>
    <div class="card bg-base-100 border border-base-200 shadow-sm mb-6">
      <div class="card-body">
        <div class="flex items-baseline gap-2">
          <h2 class="card-title text-base">Submitted Candidates</h2>
          <span class="text-sm text-base-content/50"><%= @request.agency_staffing_candidates.size %> total</span>
        </div>
        <% if @request.agency_staffing_candidates.any? %>
          <table class="table mt-2">
            <thead>
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Gender</th>
                <th>Status</th>
              </tr>
            </thead>
            <tbody>
              <% @request.agency_staffing_candidates.each do |candidate| %>
                <tr>
                  <td class="font-medium"><%= candidate.agency_staff_member.name %></td>
                  <td class="text-sm text-base-content/60"><%= candidate.agency_staff_member.email %></td>
                  <td><%= render "gender_badge", gender: candidate.agency_staff_member.gender %></td>
                  <td>
                    <% case candidate.status
                       when "submitted" %>
                      <span class="badge badge-ghost badge-sm">Awaiting Decision</span>
                    <% when "accepted" %>
                      <span class="badge badge-success badge-sm">Accepted</span>
                    <% when "rejected" %>
                      <span class="badge badge-error badge-sm">Rejected</span>
                      <% if candidate.rejection_reason.present? %>
                        <span class="text-xs text-base-content/50 block"><%= candidate.rejection_reason %></span>
                      <% end %>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% end %>
      </div>
    </div>

    <%# Add more candidates if not all vacancies filled %>
    <% remaining = @request.vacancies_requested - @request.candidates_accepted_count %>
    <% unsubmitted = @roster.reject { |m| @submitted_ids.include?(m.id) } %>
    <% if remaining > 0 && unsubmitted.any? && current_user.role_agency_admin? %>
      <div class="card bg-base-100 border border-base-200 shadow-sm">
        <div class="card-body">
          <h2 class="card-title text-base">Add More Candidates</h2>
          <p class="text-sm text-base-content/60"><%= remaining %> slot(s) still open.</p>
          <%= render "submit_form", request: @request, roster: unsubmitted, submitted_ids: @submitted_ids %>
        </div>
      </div>
    <% end %>

  <% elsif @request.status_closed? %>
    <div class="alert alert-info mb-6">
      <span>The hotel has reviewed all submitted candidates. No further action is needed for this request.</span>
    </div>
    <div class="card bg-base-100 border border-base-200 shadow-sm mb-6">
      <div class="card-body">
        <div class="flex items-baseline gap-2">
          <h2 class="card-title text-base">Submitted Candidates</h2>
          <span class="text-sm text-base-content/50"><%= @request.agency_staffing_candidates.size %> total</span>
        </div>
        <% if @request.agency_staffing_candidates.any? %>
          <table class="table mt-2">
            <thead>
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Gender</th>
                <th>Decision</th>
              </tr>
            </thead>
            <tbody>
              <% @request.agency_staffing_candidates.each do |candidate| %>
                <tr>
                  <td class="font-medium"><%= candidate.agency_staff_member.name %></td>
                  <td class="text-sm text-base-content/60"><%= candidate.agency_staff_member.email %></td>
                  <td><%= render "gender_badge", gender: candidate.agency_staff_member.gender %></td>
                  <td>
                    <% if candidate.status_accepted? %>
                      <span class="badge badge-success badge-sm">Accepted</span>
                    <% elsif candidate.status_rejected? %>
                      <div class="flex items-center gap-1.5">
                        <span class="badge badge-error badge-sm">Rejected</span>
                        <% if candidate.rejection_reason.present? %>
                          <span class="text-xs text-base-content/50"><%= candidate.rejection_reason %></span>
                        <% end %>
                      </div>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% end %>
      </div>
    </div>

  <% elsif @request.status_pending? && current_user.role_agency_admin? %>
    <%# Submit candidates form %>
    <div class="card bg-base-100 border border-base-200 shadow-sm mb-4">
      <div class="card-body">
        <h2 class="card-title text-base">Submit Candidates</h2>
        <p class="text-sm text-base-content/60 mb-3">
          Select staff from your roster to submit for this role.
        </p>
        <%= render "submit_form", request: @request, roster: @roster, submitted_ids: @submitted_ids %>
      </div>
    </div>

    <%# Decline section %>
    <div class="card bg-base-100 border border-base-200 shadow-sm">
      <div class="card-body">
        <h2 class="card-title text-base text-error">Decline Request</h2>
        <%= form_with url: decline_agency_incoming_request_path(@request), method: :patch, class: "space-y-3 mt-2" do %>
          <div class="form-control">
            <%= label_tag :declined_reason, "Reason (optional)", class: "label" %>
            <%= text_area_tag :declined_reason, nil,
                class: "textarea textarea-bordered w-full",
                rows: 2,
                placeholder: "No capacity, scheduling conflict, etc." %>
          </div>
          <%= submit_tag "Decline Request",
              class: "btn btn-error btn-outline btn-sm",
              data: { turbo_confirm: "Are you sure you want to decline this request?" } %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
