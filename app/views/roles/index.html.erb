<% content_for :title, "Staff Roles — FlexiLabour" %>

<div class="max-w-lg mx-auto">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">Staff Roles</h1>
    <%= link_to "Add Role", new_role_path, class: "btn btn-primary btn-sm" %>
  </div>

  <% if @roles.empty? %>
    <div class="text-center py-16 text-base-content/50">
      <p class="text-lg">No roles defined yet.</p>
      <p class="mt-1">Add roles that ops managers can assign to event vacancies.</p>
    </div>
  <% else %>
    <div class="card bg-base-100 border border-base-200 shadow-sm">
      <ul class="divide-y divide-base-300">
        <% @roles.each do |role| %>
          <li class="flex items-center justify-between px-4 py-3 <%= 'opacity-50' unless role.active? %>">
            <div class="flex items-center gap-2">
              <span class="font-medium"><%= role.name %></span>
              <% unless role.active? %>
                <span class="badge badge-neutral badge-xs">Disabled</span>
              <% end %>
            </div>
            <div class="flex items-center gap-1">
              <%# Edit button %>
              <%= link_to edit_role_path(role),
                  class: "btn btn-ghost btn-xs btn-square",
                  title: "Edit" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M15.232 5.232l3.536 3.536M9 13l6.586-6.586a2 2 0 012.828 0l.172.172a2 2 0 010 2.828L12 16H9v-3z" />
                </svg>
              <% end %>

              <%# Disable / Enable toggle button %>
              <%= button_to toggle_role_path(role), method: :patch,
                  class: "btn btn-ghost btn-xs btn-square #{role.active? ? 'text-warning' : 'text-success'}",
                  title: role.active? ? "Disable" : "Enable",
                  data: { turbo_confirm: "#{role.active? ? 'Disable' : 'Enable'} role \"#{role.name}\"?" } do %>
                <% if role.active? %>
                  <%# Ban / slash icon %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
                  </svg>
                <% else %>
                  <%# Check icon %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                  </svg>
                <% end %>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>