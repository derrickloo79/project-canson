<div class="card bg-base-200 border border-base-200 shadow-sm">
  <div class="card-body">
    <div class="flex items-start justify-between gap-4">
      <div>
        <% event = invitation.event_role.event %>
        <h3 class="font-semibold text-base"><%= event.event_name %></h3>
        <div class="flex items-center flex-wrap gap-x-3 gap-y-1 mt-1 text-sm text-base-content/60">
          <span class="flex items-center gap-1.5 whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <%= event.event_date&.strftime("%a, %-d %b %Y") %>
            <% if event.multi_day? && event.event_end_date %>
              <span>–</span>
              <%= event.event_end_date.strftime("%a, %-d %b %Y") %>
              <span class="badge badge-outline badge-xs uppercase">Multi-day</span>
            <% end %>
          </span>
          <span class="flex items-center gap-1.5 whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <%= event.venue %>
          </span>
          <span class="flex items-center gap-1.5 whitespace-nowrap">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <%= event.user.name %>
          </span>
        </div>
      </div>
      <% unless invitation.status_pending? %>
        <%
          badge_class = case invitation.status
                        when "accepted"   then "badge-success"
                        when "waitlisted" then "badge-warning"
                        else                   "badge-error"
                        end
          badge_label = invitation.status_waitlisted? ? "On Waiting List" : invitation.status.humanize
        %>
        <span class="badge shrink-0 <%= badge_class %>"><%= badge_label %></span>
      <% end %>
    </div>

    <dl class="grid grid-cols-2 sm:grid-cols-4 gap-x-3 text-sm mt-3">
      <div>
        <dt class="text-base-content/50 text-xs uppercase tracking-wide">Role</dt>
        <dd class="font-medium mt-0.5"><%= invitation.event_role.role_name %></dd>
      </div>
      <div>
        <dt class="text-base-content/50 text-xs uppercase tracking-wide">Shift</dt>
        <dd class="font-medium mt-0.5 flex items-center gap-1">
          <%= invitation.event_role.shift_start&.strftime("%H:%M") %> –
          <%= invitation.event_role.shift_end&.strftime("%H:%M") %>
          <% if invitation.event_role.shift_end_next_day? %>
            <span class="badge badge-warning badge-xs">+1</span>
          <% end %>
        </dd>
      </div>
      <div>
        <dt class="text-base-content/50 text-xs uppercase tracking-wide">Rate</dt>
        <dd class="font-medium mt-0.5">
          <%= invitation.event_role.rate ? "$#{number_with_precision(invitation.event_role.rate, precision: 2)}/hr" : "TBC" %>
        </dd>
      </div>
      <div>
        <dt class="text-base-content/50 text-xs uppercase tracking-wide">Invited</dt>
        <dd class="font-medium mt-0.5"><%= invitation.created_at.strftime("%-d %b %Y") %></dd>
      </div>
    </dl>

    <% clash_info ||= nil %>
    <% if clash_info %>
      <%
        same_event = clash_info.event_id == invitation.event_role.event_id
        location   = same_event ? "at this event" : "at #{clash_info.event.event_name}"
      %>
      <div role="alert" class="alert alert-warning py-2 mt-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
        </svg>
        <span class="text-sm">
          Shift conflict with your accepted <strong><%= clash_info.role_name %></strong>
          role <%= location %>
          (<%= clash_info.shift_start.strftime("%H:%M") %>–<%= clash_info.shift_end.strftime("%H:%M") %>).
          Decline or withdraw that role first.
        </span>
      </div>
    <% end %>

    <% if show_actions %>
      <% role_full = invitation.event_role.confirmed_count >= invitation.event_role.vacancies %>
      <div class="flex items-center gap-2 mt-4">
        <% if role_full && !clash_info %>
          <button type="button" class="btn btn-success btn-sm"
                  onclick="document.getElementById('waitlist-modal-<%= invitation.id %>').showModal()">
            Accept
          </button>
          <dialog id="waitlist-modal-<%= invitation.id %>" class="modal">
            <div class="modal-box">
              <h3 class="font-bold text-lg">Role is currently full</h3>
              <p class="py-3 text-base-content/70">
                All <%= invitation.event_role.vacancies %> spot(s) for
                <strong><%= invitation.event_role.role_name %></strong> have been filled.
                Would you like to be placed on the waiting list instead?
              </p>
              <div class="modal-action">
                <form method="dialog">
                  <button class="btn btn-ghost">Cancel</button>
                </form>
                <%= form_with url: waitlist_invitation_path(invitation), method: :patch do %>
                  <button type="submit" class="btn btn-warning">Join Waiting List</button>
                <% end %>
              </div>
            </div>
            <form method="dialog" class="modal-backdrop">
              <button>close</button>
            </form>
          </dialog>
        <% else %>
          <%= form_with url: accept_invitation_path(invitation), method: :patch do %>
            <button type="submit" class="btn btn-success btn-sm"
                    <%= "disabled" if clash_info %>
                    data-turbo-confirm="Accept this invitation for <%= invitation.event_role.role_name %>?">
              Accept
            </button>
          <% end %>
        <% end %>
        <%= form_with url: decline_invitation_path(invitation), method: :patch do %>
          <button type="submit" class="btn btn-outline btn-error btn-sm"
                  data-turbo-confirm="Decline this invitation?">
            Decline
          </button>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
