<div class="card bg-base-100 border border-base-200 shadow-sm">
  <div class="card-body">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h3 class="font-semibold text-base"><%= invitation.event_role.event.event_name %></h3>
        <p class="text-sm text-base-content/60 mt-0.5">
          <%= invitation.event_role.event.venue %>
          &mdash;
          <%= invitation.event_role.event.event_date&.strftime("%a, %-d %b %Y") %>
        </p>
      </div>
      <% unless invitation.status_pending? %>
        <span class="badge shrink-0 <%= invitation.status_accepted? ? 'badge-success' : 'badge-error' %>">
          <%= invitation.status.humanize %>
        </span>
      <% end %>
    </div>

    <dl class="grid grid-cols-2 sm:grid-cols-4 gap-x-4 gap-y-2 text-sm mt-3">
      <div>
        <dt class="text-base-content/50 text-xs uppercase tracking-wide">Role</dt>
        <dd class="font-medium mt-0.5"><%= invitation.event_role.role_name %></dd>
      </div>
      <div>
        <dt class="text-base-content/50 text-xs uppercase tracking-wide">Shift</dt>
        <dd class="font-medium mt-0.5 flex items-center gap-1">
          <%= invitation.event_role.shift_start&.strftime("%H:%M") %> –
          <%= invitation.event_role.shift_end&.strftime("%H:%M") %>
          <% if invitation.event_role.shift_end_next_day? %>
            <span class="badge badge-warning badge-xs">+1</span>
          <% end %>
        </dd>
      </div>
      <div>
        <dt class="text-base-content/50 text-xs uppercase tracking-wide">Rate</dt>
        <dd class="font-medium mt-0.5">
          <%= invitation.event_role.rate ? "$#{number_with_precision(invitation.event_role.rate, precision: 2)}/hr" : "TBC" %>
        </dd>
      </div>
      <div>
        <dt class="text-base-content/50 text-xs uppercase tracking-wide">Invited</dt>
        <dd class="font-medium mt-0.5"><%= invitation.created_at.strftime("%-d %b %Y") %></dd>
      </div>
    </dl>

    <% clashing_role ||= nil %>
    <% if clashing_role %>
      <div role="alert" class="alert alert-warning py-2 mt-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
        </svg>
        <span class="text-sm">
          Shift conflict with your accepted <strong><%= clashing_role.role_name %></strong>
          role (<%= clashing_role.shift_start.strftime("%H:%M") %>–<%= clashing_role.shift_end.strftime("%H:%M") %>).
          Decline or withdraw that role first.
        </span>
      </div>
    <% end %>

    <% if show_actions %>
      <div class="flex items-center gap-2 mt-4">
        <%= form_with url: accept_invitation_path(invitation), method: :patch do %>
          <button type="submit" class="btn btn-success btn-sm"
                  <%= "disabled" if clashing_role %>
                  data-turbo-confirm="Accept this invitation for <%= invitation.event_role.role_name %>?">
            Accept
          </button>
        <% end %>
        <%= form_with url: decline_invitation_path(invitation), method: :patch do %>
          <button type="submit" class="btn btn-outline btn-error btn-sm"
                  data-turbo-confirm="Decline this invitation?">
            Decline
          </button>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
