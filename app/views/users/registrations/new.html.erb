<% content_for :title, "Sign Up — FlexiLabour" %>

<div class="min-h-[70vh] flex items-center justify-center">
  <div class="card bg-base-200 shadow-md w-full max-w-sm">
    <div class="card-body">
      <h2 class="card-title text-2xl justify-center mb-1">Create Account</h2>
      <p class="text-center text-base-content/60 text-sm mb-4">FlexiLabour Staff Management</p>

      <%= form_for(resource, as: resource_name,
          url: registration_path(resource_name),
          html: { class: "space-y-4" }) do |f| %>

        <%= render "users/shared/error_messages", resource: resource %>

        <div class="form-control">
          <%= f.label :name, class: "label" %>
          <%= f.text_field :name, autofocus: true, autocomplete: "name",
              class: "input input-bordered w-full" %>
        </div>

        <div class="form-control">
          <%= f.label :email, class: "label" %>
          <%= f.email_field :email, autocomplete: "email",
              class: "input input-bordered w-full" %>
        </div>

        <div class="form-control">
          <%= f.label :password, class: "label" %>
          <% if @minimum_password_length %>
            <span class="label-text-alt text-base-content/50">
              Minimum <%= @minimum_password_length %> characters
            </span>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password",
              class: "input input-bordered w-full" %>
        </div>

        <div class="form-control">
          <%= f.label :password_confirmation, class: "label" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
              class: "input input-bordered w-full" %>
        </div>

        <div class="form-control mt-2">
          <%= f.submit "Sign Up", class: "btn btn-primary w-full" %>
        </div>
      <% end %>

      <div class="divider text-xs text-base-content/40">or</div>

      <div class="text-center text-sm">
        <%= render "users/shared/links" %>
      </div>
    </div>
  </div>
</div>
