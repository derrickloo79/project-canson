<% content_for :title, "Forgot Password — FlexiLabour" %>

<div class="min-h-[70vh] flex items-center justify-center">
  <div class="card bg-base-200 shadow-md w-full max-w-sm">
    <div class="card-body">
      <h2 class="card-title text-2xl justify-center mb-1">Forgot Password</h2>
      <p class="text-center text-base-content/60 text-sm mb-2">Enter your email to receive reset instructions.</p>

      <%= form_for(resource, as: resource_name,
          url: password_path(resource_name),
          html: { method: :post }) do |f| %>

        <%= render "users/shared/error_messages", resource: resource %>

        <fieldset class="fieldset">
          <legend class="fieldset-legend">Email</legend>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "input w-full", placeholder: "email@example.com" %>
        </fieldset>

        <%= f.submit "Send Reset Instructions", class: "btn btn-primary w-full mt-2" %>
      <% end %>

      <div class="text-center text-sm mt-3 text-base-content/60">
        Back to <%= link_to "Sign in", new_session_path(resource_name), class: "link link-primary" %>
      </div>
    </div>
  </div>
</div>
