<% content_for :title, "Invite Agency — FlexiLabour" %>

<div class="max-w-lg mx-auto">
  <div class="flex mb-6">
    <%= link_to agencies_path, class: "btn btn-ghost btn-sm btn-square" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    <% end %>
  </div>

  <div class="card bg-base-200 shadow-sm">
    <div class="card-body">
      <h1 class="card-title text-xl mb-1">Invite Agency</h1>
      <p class="text-sm text-base-content/60 mb-4">
        An email with a registration link will be sent to the agency's contact address.
      </p>

      <%= form_with model: @agency, url: agencies_path do |f| %>
        <% if @agency.errors.any? %>
          <div role="alert" class="alert alert-error mb-4">
            <ul class="list-disc list-inside text-sm">
              <% @agency.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <fieldset class="fieldset">
          <legend class="fieldset-legend">Agency Name <span class="text-error">*</span></legend>
          <%= f.text_field :name, class: "input w-full", placeholder: "Acme Staffing Agency", required: true %>
        </fieldset>

        <fieldset class="fieldset">
          <legend class="fieldset-legend">Contact Email <span class="text-error">*</span></legend>
          <%= f.email_field :contact_email, class: "input w-full", placeholder: "admin@agency.com", required: true %>
          <span class="fieldset-label text-base-content/50">The invitation will be sent to this address.</span>
        </fieldset>

        <fieldset class="fieldset">
          <legend class="fieldset-legend">Phone</legend>
          <%= f.telephone_field :phone, class: "input w-full", placeholder: "+65 9000 0000" %>
        </fieldset>

        <fieldset class="fieldset">
          <legend class="fieldset-legend">Website</legend>
          <%= f.url_field :website, class: "input w-full", placeholder: "https://agency.com" %>
        </fieldset>

        <div class="mt-4">
          <%= f.submit "Send Invitation", class: "btn btn-primary w-full" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
